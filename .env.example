# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Overtalking account refresh token (run scripts/get-refresh-token.ts to obtain)
GOOGLE_REFRESH_TOKEN=

# Google Calendar IDs (found in each calendar's settings page)
RECORDINGS_CALENDAR_ID=
BLACKOUT_CALENDAR_ID=

# Session signing secret (any long random string)
SESSION_SECRET=

# App
PORT=3001
CLIENT_URL=https://overtalking-booking.kdrisc01.uk
